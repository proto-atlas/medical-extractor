# Next.js (next dev) 用ローカル環境変数テンプレート
#
# 使い方:
#   1. このファイルを .env.local としてコピー
#   2. 実際の値を設定（.env.local は .gitignore で除外されるため安全）
#
# 本ファイル自体は commit 可能（ダミー値しか書かない）

# PasswordGate で入力するアクセスキー（任意に決める、8 文字以上推奨）
ACCESS_PASSWORD=change-me-to-your-own-password

# Anthropic API キー（https://console.anthropic.com/settings/keys で発行）
# ⚠️ 必ず Spend Limit を設定してから使用すること（$5〜$10/月 推奨）
ANTHROPIC_API_KEY=<your-anthropic-api-key>
