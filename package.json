{
  "name": "medical-extractor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.0.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "preview": "next build --webpack && opennextjs-cloudflare build --skipNextBuild && opennextjs-cloudflare preview",
    "deploy": "next build --webpack && opennextjs-cloudflare build --skipNextBuild && opennextjs-cloudflare deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "screenshots": "playwright test --project=screenshots",
    "eval:soap": "node scripts/run-soap-eval.mjs",
    "lighthouse": "node scripts/run-lighthouse.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "a11y": "playwright test --project=chromium e2e/a11y.spec.ts e2e/target-size.spec.ts",
    "verify:evidence": "node scripts/verify-evidence.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "verify:portfolio": "npm run typecheck && npm run lint && npm run test:coverage && npm run build && cross-env CI=true npm run e2e -- --project=chromium --workers=1 && npm run verify:evidence",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@opennextjs/cloudflare": "^1.19.3",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "chrome-launcher": "^1.2.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.0.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lighthouse": "^13.1.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  }
}
